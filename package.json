{
    "name": "hazelspam",
    "private": true,
    "version": "1.3.0",
    "packageManager": "pnpm@10.30.3",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "lint": "eslint src tests scripts vite.config.ts vitest.config.ts eslint.config.js --max-warnings=0",
        "test": "vitest run",
        "typecheck": "vue-tsc -b",
        "build": "pnpm typecheck && vite build && node scripts/minifyUserscript.js && node scripts/generateLatestReleaseManifest.js",
        "check": "pnpm lint && pnpm test && pnpm typecheck",
        "preview": "pnpm typecheck && vite preview",
        "format": "prettier --write src/"
    },
    "dependencies": {
        "@primeuix/themes": "^2.0.3",
        "axios": "^1.13.4",
        "lodash": "^4.17.23",
        "mitt": "^3.0.1",
        "pinia": "^3.0.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.4",
        "vue": "^3.5.27"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/lodash": "^4.17.23",
        "@types/node": "~25.0.10",
        "@vitejs/plugin-vue": "^6.0.3",
        "eslint": "^10.0.3",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "terser": "^5.46.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^7.3.1",
        "vite-plugin-monkey": "^7.1.9",
        "vite-svg-loader": "^5.1.0",
        "vitest": "^4.0.18",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.4"
    }
}
